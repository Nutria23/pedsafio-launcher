{
  "name": "pedsafio-launcher",
  "version": "1.0.0",
  "description": "Launcher profesional para Minecraft con auto-updater y diseño moderno",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^3.1.2"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.pedsafio.launcher",
    "productName": "Pedsafio Launcher",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pedsafio Launcher",
      "runAfterFinish": true
    },
    "msi": {
      "oneClick": false,
      "shortcutName": "Pedsafio Launcher",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
